# HMRC OAuth — register at https://developer.service.hmrc.gov.uk/
# Subscribe your app to MTD Income Tax / Self Assessment APIs you need.
# Redirect URI here must match the one registered on the application (character-for-character).

HMRC_CLIENT_ID=
HMRC_CLIENT_SECRET=
HMRC_REDIRECT_URI=http://localhost:3000/api/hmrc/callback

# sandbox = test-www.tax.service.gov.uk + test-api (default).
# production = live Government Gateway + api.service.hmrc.gov.uk
HMRC_OAUTH_ENV=sandbox

# Optional overrides if HMRC documentation changes:
# HMRC_AUTHORIZE_URL=
# HMRC_TOKEN_URL=

# Must match API subscriptions on your HMRC application (space-separated).
# If consent fails, try read:self-assessment only, or hello for platform smoke tests:
HMRC_OAUTH_SCOPE=read:self-assessment write:self-assessment
